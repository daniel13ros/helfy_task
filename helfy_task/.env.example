# Template for local setup. Copy to `.env` docker compose loads that
# automatically and adjust values/secrets as needed:
#   cp .env.example .env

# Image versions 
MYSQL_IMAGE_TAG=8.0
DEBEZIUM_IMAGE_TAG=2.7.3.Final
CURL_IMAGE_TAG=8.9.1

# MySQL 
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=app_db
MYSQL_HOST_PORT=3307

# App DB user used by the backend, created by mysql/02-create-users.sh
APP_DB_USER=app_user
APP_DB_PASSWORD=app_password

# Replication user used by the Debezium connector, created by mysql/02-create-users.sh
DEBEZIUM_DB_USER=debezium
DEBEZIUM_DB_PASSWORD=dbz_password

# Backend 
BACKEND_HOST_PORT=3000
LOG_LEVEL=info
TOKEN_TTL_MS=86400000

# Frontend
FRONTEND_HOST_PORT=8080

# Kafka Connect / Debezium connector
CONNECT_HOST_PORT=8083
CONNECT_GROUP_ID=1
CONNECT_CONFIG_STORAGE_TOPIC=connect_configs
CONNECT_OFFSET_STORAGE_TOPIC=connect_offsets
CONNECT_STATUS_STORAGE_TOPIC=connect_statuses
CONNECTOR_NAME=mysql-users-connector
DATABASE_SERVER_ID=184054
TOPIC_PREFIX=dbserver1

# CDC consumer 
KAFKA_CONSUMER_GROUP_ID=cdc-consumer-group
